datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?
  chats    Chat[]
}

model Chat {
  id        String   @id @default(uuid())
  content   String
  role      String
  userId    String
  sessionId String // <--- Ye line lazmi honi chahiye
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
